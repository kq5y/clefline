{
  "compilerOptions": {
    "target": "es2020",
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "noUnusedLocals": true,
    "outDir": "build/dist",
    "declaration": true,
    "emitDeclarationOnly": true,
    "sourceMap": false,
    "typeRoots": ["./node_modules/@types"],
    "skipLibCheck": true
  },
  "include": ["./src"],
  "exclude": [
    "node_modules",
    "dist",
    "demo",
    "build",
    "test",
    "./src/VexFlowPatch/"
  ]
}
