{
  "name": "clefline",
  "version": "0.0.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit",
    "lint": "oxlint . --react-plugin --jsx-a11y-plugin --import-plugin --vitest-plugin -D correctness -D suspicious -A react-in-jsx-scope -A no-unassigned-import",
    "format": "oxfmt . --write",
    "format:check": "oxfmt . --check",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "check": "pnpm typecheck && pnpm lint && pnpm test"
  },
  "dependencies": {
    "fast-xml-parser": "^5.7.2",
    "jszip": "^3.10.1",
    "lucide-react": "^1.14.0",
    "opensheetmusicdisplay": "^1.9.7",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tone": "^15.1.22",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "jsdom": "^29.1.1",
    "oxfmt": "^0.47.0",
    "oxlint": "^1.62.0",
    "playwright": "^1.59.1",
    "typescript": "~6.0.2",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  }
}
